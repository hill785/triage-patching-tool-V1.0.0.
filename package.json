{
  "name": "triage-patching-tool",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": "^18.20.0 || ^20.10.0 || ^22.0.0",
    "pnpm": "^9.0.0 || ^10.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm --filter web build",
    "preview": "pnpm --filter web preview",
    "lint": "eslint apps/web/src --ext .ts,.tsx",
    "lint:fix": "eslint apps/web/src --ext .ts,.tsx --fix",
    "test": "vitest run",
    "test:debug": "vitest --inspect-brk --no-file-parallelism run"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0",
    "@vitest/coverage-v8": "^1.6.0"
  }
}
